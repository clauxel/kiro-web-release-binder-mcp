{
  "name": "kirowebreleasebinder",
  "title": "Kiro Web Release Binder",
  "description": "A remote MCP release gate for Kiro projects, task lists, environment checks, acceptance criteria, and delivery receipts.",
  "version": "1.0.0",
  "websiteUrl": "https://kirowebreleasebinder.clauxel.com/",
  "documentationUrl": "https://kirowebreleasebinder.clauxel.com/mcp/",
  "endpointUrl": "https://kirowebreleasebinder.clauxel.com/mcp",
  "transport": "streamable-http",
  "authentication": {
    "type": "bearer",
    "required": true,
    "header": "Authorization",
    "format": "Bearer <paid-token>"
  },
  "paidAccess": {
    "required": true,
    "checkoutUrl": "https://kirowebreleasebinder.clauxel.com/api/agent-checkout",
    "tokenStatusUrl": "https://kirowebreleasebinder.clauxel.com/api/mcp-token/status",
    "tokenClaimUrl": "https://kirowebreleasebinder.clauxel.com/api/mcp-token/claim",
    "defaultPlan": "team",
    "pricing": [
      {
        "id": "starter",
        "name": "Starter",
        "monthlyUsd": 49
      },
      {
        "id": "team",
        "name": "Team",
        "monthlyUsd": 149
      },
      {
        "id": "studio",
        "name": "Studio",
        "monthlyUsd": 349
      }
    ]
  },
